{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "moduleResolution": "node",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "strict": false,
      "noEmit": true,
      "baseUrl": "..",
      "paths": {
        "@/*": ["src/*"]
      }
    },
    "include": ["./**/*.ts"]
  }